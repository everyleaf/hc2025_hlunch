<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @prompt.title %></h1>
    <div class="btn-group" role="group">
      <%= link_to "編集", edit_prompt_path(@prompt), class: "btn btn-primary" %>
      <%= button_to "削除", prompt_path(@prompt), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "btn btn-danger" %>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h5 class="card-title">プロンプト本文</h5>
      <p class="card-text" style="white-space: pre-wrap;"><%= @prompt.prompt %></p>
    </div>
    <div class="card-footer text-muted">
      作成日時: <%= @prompt.created_at.strftime("%Y年%m月%d日 %H:%M") %>
      <% if @prompt.updated_at != @prompt.created_at %>
        | 更新日時: <%= @prompt.updated_at.strftime("%Y年%m月%d日 %H:%M") %>
      <% end %>
    </div>
  </div>

  <div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3>関連レシピ</h3>
      <div class="btn-group" role="group">
        <%= button_to "LLMでレシピ生成", generate_recipe_prompt_path(@prompt), method: :post, class: "btn btn-primary" %>
        <%= link_to "新規レシピ作成", new_prompt_recipe_path(@prompt), class: "btn btn-success" %>
      </div>
    </div>

    <% if @prompt.recipes.any? %>
      <div class="list-group">
        <% @prompt.recipes.order(created_at: :desc).each do |recipe| %>
          <div class="list-group-item">
            <div class="d-flex w-100 justify-content-between align-items-start">
              <div class="flex-grow-1">
                <h5 class="mb-1">
                  <%= link_to recipe.title, recipe_path(recipe), class: "text-decoration-none" %>
                </h5>
                <small class="text-muted">
                  <%= recipe.created_at.strftime("%Y年%m月%d日 %H:%M") %>
                </small>
              </div>
              <div class="btn-group ms-3" role="group">
                <%= link_to "詳細", recipe_path(recipe), class: "btn btn-sm btn-outline-secondary" %>
                <%= link_to "編集", edit_recipe_path(recipe), class: "btn btn-sm btn-outline-primary" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info">
        レシピがまだ登録されていません。
      </div>
    <% end %>
  </div>

  <div class="mt-3">
    <%= link_to "一覧に戻る", prompts_path, class: "btn btn-outline-secondary" %>
  </div>
</div>
